[ -> text.carve meta.span.inline.carve punctuation.definition.span.begin.carve
note -> text.carve meta.span.inline.carve string.other.span.carve
] -> text.carve meta.span.inline.carve punctuation.definition.span.end.carve
{ -> text.carve meta.attributes.carve
.a -> text.carve meta.attributes.carve entity.other.attribute-name.class.carve
  -> text.carve meta.attributes.carve
.b -> text.carve meta.attributes.carve entity.other.attribute-name.class.carve
  -> text.carve meta.attributes.carve
#n -> text.carve meta.attributes.carve entity.other.attribute-name.id.carve
  -> text.carve meta.attributes.carve
key -> text.carve meta.attributes.carve entity.other.attribute-name.carve
=val} -> text.carve meta.attributes.carve
\n -> text.carve
