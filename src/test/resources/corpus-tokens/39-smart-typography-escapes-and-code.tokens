Escaped  -> text.carve
\\- -> text.carve constant.character.escape.carve
> and  -> text.carve
\\. -> text.carve constant.character.escape.carve
.. stay; code  -> text.carve
` -> text.carve markup.raw.inline.carve keyword.operator.raw.carve
a -- b ... -> text.carve markup.raw.inline.carve markup.raw.inline.content.carve
` -> text.carve markup.raw.inline.carve keyword.operator.raw.carve
 stays.\n -> text.carve
