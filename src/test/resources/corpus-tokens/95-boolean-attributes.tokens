Press  -> text.carve
[ -> text.carve meta.span.inline.carve keyword.operator.span.begin.carve
Tab -> text.carve meta.span.inline.carve string.other.span.carve
] -> text.carve meta.span.inline.carve keyword.operator.span.end.carve
{kbd} -> text.carve meta.attributes.carve
 to indent.\n -> text.carve
