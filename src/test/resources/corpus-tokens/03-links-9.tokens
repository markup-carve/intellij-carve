[ -> text.carve meta.span.inline.carve keyword.control.span.begin.carve
some text -> text.carve meta.span.inline.carve string.other.span.carve
] -> text.carve meta.span.inline.carve keyword.control.span.end.carve
{ -> text.carve meta.attributes.carve
.highlight -> text.carve meta.attributes.carve entity.other.attribute-name.class.carve
  -> text.carve meta.attributes.carve
#note -> text.carve meta.attributes.carve entity.other.attribute-name.id.carve
  -> text.carve meta.attributes.carve
key -> text.carve meta.attributes.carve entity.other.attribute-name.carve
=val} -> text.carve meta.attributes.carve
\n -> text.carve
