[ -> text.carve meta.span.inline.carve keyword.operator.span.begin.carve
a /b/ c -> text.carve meta.span.inline.carve string.other.span.carve
] -> text.carve meta.span.inline.carve keyword.operator.span.end.carve
{ -> text.carve meta.attributes.carve
.x -> text.carve meta.attributes.carve entity.other.attribute-name.class.carve
} -> text.carve meta.attributes.carve
 and  -> text.carve
[ -> text.carve meta.link.inline.carve keyword.operator.link.begin.carve
t -> text.carve meta.link.inline.carve string.other.link.title.carve
] -> text.carve meta.link.inline.carve keyword.operator.link.end.carve
( -> text.carve meta.link.inline.carve keyword.operator.metadata.begin.carve
u -> text.carve meta.link.inline.carve markup.underline.link.carve
) -> text.carve meta.link.inline.carve keyword.operator.metadata.end.carve
\n -> text.carve
