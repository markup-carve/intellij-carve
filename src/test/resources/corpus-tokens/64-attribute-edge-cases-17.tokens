[ -> text.carve meta.span.inline.carve keyword.operator.span.begin.carve
x -> text.carve meta.span.inline.carve string.other.span.carve
] -> text.carve meta.span.inline.carve keyword.operator.span.end.carve
{ -> text.carve meta.attributes.carve
.a1 -> text.carve meta.attributes.carve entity.other.attribute-name.class.carve
  -> text.carve meta.attributes.carve
#b2 -> text.carve meta.attributes.carve entity.other.attribute-name.id.carve
  -> text.carve meta.attributes.carve
k3 -> text.carve meta.attributes.carve entity.other.attribute-name.carve
=v} -> text.carve meta.attributes.carve
\n -> text.carve
