Run  -> text.carve
` -> text.carve markup.raw.inline.carve keyword.control.raw.carve
a %% b -> text.carve markup.raw.inline.carve markup.raw.inline.content.carve
` -> text.carve markup.raw.inline.carve keyword.control.raw.carve
 then done.  -> text.carve
%% gone -> text.carve comment.line.percent.carve
\n -> text.carve
