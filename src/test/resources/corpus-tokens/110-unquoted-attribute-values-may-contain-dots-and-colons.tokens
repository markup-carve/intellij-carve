[ -> text.carve meta.span.inline.carve punctuation.definition.span.begin.carve
a -> text.carve meta.span.inline.carve string.other.span.carve
] -> text.carve meta.span.inline.carve punctuation.definition.span.end.carve
{ -> text.carve meta.attributes.carve
k -> text.carve meta.attributes.carve entity.other.attribute-name.carve
=v -> text.carve meta.attributes.carve
.w -> text.carve meta.attributes.carve entity.other.attribute-name.class.carve
} -> text.carve meta.attributes.carve
\n -> text.carve
