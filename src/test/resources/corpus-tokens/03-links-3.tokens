[A](/a 'plain') and  -> text.carve
[ -> text.carve meta.link.inline.carve punctuation.definition.link.begin.carve
B -> text.carve meta.link.inline.carve string.other.link.title.carve
] -> text.carve meta.link.inline.carve punctuation.definition.link.end.carve
( -> text.carve meta.link.inline.carve punctuation.definition.metadata.begin.carve
/b -> text.carve meta.link.inline.carve markup.underline.link.carve
 " -> text.carve meta.link.inline.carve
Bob's -> text.carve meta.link.inline.carve string.quoted.double.link-title.carve
" -> text.carve meta.link.inline.carve
) -> text.carve meta.link.inline.carve punctuation.definition.metadata.end.carve
\n -> text.carve
