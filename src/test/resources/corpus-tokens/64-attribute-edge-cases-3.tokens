[ -> text.carve meta.span.inline.carve punctuation.definition.span.begin.carve
x -> text.carve meta.span.inline.carve string.other.span.carve
] -> text.carve meta.span.inline.carve punctuation.definition.span.end.carve
{ -> text.carve meta.attributes.carve
data-x -> text.carve meta.attributes.carve entity.other.attribute-name.carve
= -> text.carve meta.attributes.carve
"{y}" -> text.carve meta.attributes.carve string.quoted.double.attribute.carve
} -> text.carve meta.attributes.carve
\n -> text.carve
