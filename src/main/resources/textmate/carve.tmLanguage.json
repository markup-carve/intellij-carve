{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Carve",
  "scopeName": "text.carve",
  "patterns": [
    {
      "include": "#thematic-break"
    },
    {
      "include": "#frontmatter"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#headings"
    },
    {
      "include": "#code-blocks"
    },
    {
      "include": "#raw-blocks"
    },
    {
      "include": "#divs"
    },
    {
      "include": "#tables"
    },
    {
      "include": "#block-quotes"
    },
    {
      "include": "#lists"
    },
    {
      "include": "#definitions"
    },
    {
      "include": "#links"
    },
    {
      "include": "#images"
    },
    {
      "include": "#footnotes"
    },
    {
      "include": "#citations"
    },
    {
      "include": "#code-callouts"
    },
    {
      "include": "#critic-markup"
    },
    {
      "include": "#emphasis"
    },
    {
      "include": "#attributes"
    },
    {
      "include": "#raw-inline"
    },
    {
      "include": "#inline-literal"
    },
    {
      "include": "#inline-code"
    },
    {
      "include": "#trailing-comment"
    },
    {
      "include": "#math"
    },
    {
      "include": "#cross-reference"
    },
    {
      "include": "#autolink"
    },
    {
      "include": "#extension-inline"
    },
    {
      "include": "#mentions-tags"
    },
    {
      "include": "#smart-typography"
    },
    {
      "include": "#hard-break"
    }
  ],
  "repository": {
    "frontmatter": {
      "patterns": [
        {
          "comment": "Frontmatter open fence. The IntelliJ TextMate engine treats the document-start anchor `\\A` like line-start `^`, so a `\\A`-anchored bare `---` would also fire mid-document and swallow the rest of the file as frontmatter. To restore document-start semantics in a line-based engine, the open fence requires a typed format token (`---json`, `--- toml`, ...): a lone `---` line never triggers frontmatter and is left to the thematic-break rule (which runs first). A bare `---` open fence is therefore highlighted as a thematic break, matching the spec note that a bare `---` is frontmatter only when a closing `---` exists ahead -- a closer lookahead a line-based grammar cannot perform.",
          "name": "meta.frontmatter.carve",
          "begin": "^(---)\\s*([A-Za-z0-9_-]+)\\s*$",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.frontmatter.begin.carve"
            },
            "2": {
              "name": "entity.name.type.frontmatter.carve"
            }
          },
          "end": "^(---)\\s*$",
          "endCaptures": {
            "1": {
              "name": "keyword.control.frontmatter.end.carve"
            }
          },
          "patterns": [
            {
              "name": "string.unquoted.frontmatter.carve",
              "match": ".+"
            }
          ]
        }
      ]
    },
    "thematic-break": {
      "patterns": [
        {
          "comment": "A standalone line of three or more `-`, `*`, or `_` (optionally followed by trailing whitespace) is a thematic break. Listed before #frontmatter so a lone `---` line is claimed here rather than mis-detected as a frontmatter open fence (see #frontmatter).",
          "name": "meta.separator.thematic-break.carve",
          "match": "^(-{3,}|\\*{3,}|_{3,})\\s*$",
          "captures": {
            "1": {
              "name": "keyword.control.thematic-break.carve"
            }
          }
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.block.carve",
          "begin": "^\\s*%%%\\s*$",
          "end": "^\\s*%%%\\s*$"
        },
        {
          "name": "comment.line.percent.carve",
          "match": "^\\s*%%(?!%).*$"
        }
      ]
    },
    "trailing-comment": {
      "patterns": [
        {
          "name": "comment.line.percent.carve",
          "match": "(?<=[ \\t])%%.*$"
        }
      ]
    },
    "trailing-comment-cell": {
      "patterns": [
        {
          "name": "comment.line.percent.carve",
          "match": "(?<=[ \\t])%%[^|]*"
        }
      ]
    },
    "headings": {
      "patterns": [
        {
          "name": "markup.heading.carve",
          "match": "^(#{1,6})(\\s+)(.+)$",
          "captures": {
            "1": {
              "name": "keyword.control.heading.carve"
            },
            "3": {
              "name": "entity.name.section.carve",
              "patterns": [
                {
                  "include": "#trailing-comment"
                }
              ]
            }
          }
        }
      ]
    },
    "code-blocks": {
      "patterns": [
        {
          "name": "markup.raw.block.fenced.code.carve",
          "begin": "^(`{3,}|~{3,})[ \\t]*([^`~\\s\\[\"]+)?[ \\t]*(?:(\"[^\"]*\")[ \\t]*(\\[[^\\]]*\\])?|(\\[[^\\]]*\\])[ \\t]*(\"[^\"]*\")?)?[ \\t]*$",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.raw.begin.carve"
            },
            "2": {
              "name": "entity.name.type.language.carve"
            },
            "3": {
              "name": "string.quoted.double.carve"
            },
            "4": {
              "name": "entity.name.label.carve"
            },
            "5": {
              "name": "entity.name.label.carve"
            },
            "6": {
              "name": "string.quoted.double.carve"
            }
          },
          "end": "^(`{3,}|~{3,})\\s*$",
          "endCaptures": {
            "1": {
              "name": "keyword.control.raw.end.carve"
            }
          }
        }
      ]
    },
    "raw-blocks": {
      "patterns": [
        {
          "name": "markup.raw.block.carve",
          "begin": "^(%{3,})\\s*([^\\s]+)?\\s*$",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.raw.begin.carve"
            },
            "2": {
              "name": "entity.name.type.language.carve"
            }
          },
          "end": "^(%{3,})\\s*$",
          "endCaptures": {
            "1": {
              "name": "keyword.control.raw.end.carve"
            }
          }
        }
      ]
    },
    "divs": {
      "patterns": [
        {
          "name": "markup.other.div.carve",
          "match": "^\\s*(:::+)\\s*([^\\s{\\[\"]+)?\\s*(?:(\"[^\"]*\")\\s*(\\[[^\\]]*\\])?|(\\[[^\\]]*\\])\\s*(\"[^\"]*\")?)?",
          "captures": {
            "1": {
              "name": "keyword.control.div.carve"
            },
            "2": {
              "name": "entity.name.type.div.carve"
            },
            "3": {
              "name": "string.quoted.double.carve"
            },
            "4": {
              "name": "entity.name.label.carve"
            },
            "5": {
              "name": "entity.name.label.carve"
            },
            "6": {
              "name": "string.quoted.double.carve"
            }
          }
        }
      ]
    },
    "tables": {
      "patterns": [
        {
          "comment": "GFM delimiter/alignment row: a whole line of only pipes, dashes, optional alignment colons, and whitespace (e.g. `|---|---|`, `|:---:|`). Gated by a full-row lookahead so an ordinary data cell that merely contains dashes is NOT mis-scoped. Note: TextMate rules are line-local and do not track table position, so a dash/colon-only row that is NOT the parser's second-row delimiter is also highlighted here -- rare and cosmetic.",
          "name": "markup.table.row.separator.carve",
          "begin": "^(?=\\s*\\|(?:[ \\t]*:?-+:?[ \\t]*\\|)+[ \\t]*$)",
          "end": "$",
          "patterns": [
            {
              "match": "(?<=\\|)[ \\t]*(:?-+:?)[ \\t]*(?=\\|)",
              "captures": {
                "1": {
                  "name": "keyword.control.table.separator.carve"
                }
              }
            },
            {
              "match": "\\|",
              "name": "keyword.control.separator.table.carve"
            }
          ]
        },
        {
          "name": "markup.table.row.carve",
          "begin": "^(?=\\s*\\|)",
          "end": "$",
          "patterns": [
            {
              "match": "\\|=",
              "name": "keyword.control.table.header.carve"
            },
            {
              "match": "(?<=\\|)\\s*(\\^)\\s*(?=\\|)",
              "captures": {
                "1": {
                  "name": "keyword.control.table.rowspan.carve"
                }
              }
            },
            {
              "match": "(?<=\\|)\\s*(<)\\s*(?=\\|)",
              "captures": {
                "1": {
                  "name": "keyword.control.table.colspan.carve"
                }
              }
            },
            {
              "match": "\\|",
              "name": "keyword.control.separator.table.carve"
            },
            {
              "include": "#trailing-comment-cell"
            },
            {
              "include": "#inline-code"
            },
            {
              "include": "#extension-inline"
            },
            {
              "include": "#critic-markup"
            },
            {
              "include": "#emphasis"
            },
            {
              "include": "#links"
            },
            {
              "include": "#images"
            },
            {
              "include": "#autolink"
            },
            {
              "include": "#attributes"
            }
          ]
        },
        {
          "name": "markup.table.continuation.carve",
          "match": "^(\\+)(.*\\|\\s*)$",
          "captures": {
            "1": {
              "name": "keyword.control.table.continuation.carve"
            }
          }
        },
        {
          "name": "markup.table.caption.carve",
          "match": "^\\s*(\\^)\\s+(.+)$",
          "captures": {
            "1": {
              "name": "keyword.control.caption.carve"
            },
            "2": {
              "name": "string.unquoted.caption.carve",
              "patterns": [
                {
                  "include": "#trailing-comment"
                }
              ]
            }
          }
        }
      ]
    },
    "block-quotes": {
      "patterns": [
        {
          "name": "markup.quote.carve",
          "begin": "^\\s*(>+)\\s?",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.quote.carve"
            }
          },
          "end": "$",
          "patterns": [
            {
              "include": "#trailing-comment"
            }
          ]
        }
      ]
    },
    "lists": {
      "patterns": [
        {
          "match": "^(\\s*)(::)(\\s+)(.*)$",
          "captures": {
            "2": {
              "name": "keyword.control.list.begin.carve"
            },
            "4": {
              "name": "entity.name.tag.definition.term.carve"
            }
          }
        },
        {
          "comment": "A lone `+` at the marker column is the list-continuation marker, not a bullet (`+` is never a bullet in Carve).",
          "name": "markup.list.continuation.carve",
          "match": "^(\\s*)(\\+)(\\s*)$",
          "captures": {
            "2": {
              "name": "keyword.control.list.continuation.carve"
            }
          }
        },
        {
          "name": "markup.list.unnumbered.carve",
          "comment": "A marker line may carry several markers (`- - A` opens two nested lists), so scope each one, not only the line-anchored first.",
          "match": "^(\\s*)([-*])(\\s+)((?:[-*]\\s+)*)(\\[[ xX\\-_>?]\\]\\s+)?",
          "captures": {
            "2": {
              "name": "keyword.control.list.begin.carve"
            },
            "4": {
              "name": "keyword.control.list.begin.carve"
            },
            "5": {
              "name": "keyword.control.task-list.carve"
            }
          }
        },
        {
          "comment": "Ordered markers use a trailing `.` or `)` only. A parenthesized `(1)` / `(a)` form is NOT a marker in Carve (it is too easily confused with prose), so no leading `(`.",
          "name": "markup.list.numbered.carve",
          "match": "^(\\s*)([0-9]+[.)]|[A-Za-z][.)]|[ivxlcdmIVXLCDM]+[.)])\\s+",
          "captures": {
            "2": {
              "name": "keyword.control.list.begin.carve"
            }
          }
        },
        {
          "name": "markup.list.definition.carve",
          "match": "^(\\s*)(:)\\s+",
          "captures": {
            "2": {
              "name": "keyword.control.list.begin.carve"
            }
          }
        }
      ]
    },
    "definitions": {
      "patterns": [
        {
          "name": "meta.link.reference.definition.carve",
          "match": "^\\s*(\\[[^\\]]+\\]:)\\s+(\\S+)",
          "captures": {
            "1": {
              "name": "entity.name.reference.link.carve"
            },
            "2": {
              "name": "markup.underline.link.carve"
            }
          }
        },
        {
          "name": "meta.abbreviation.definition.carve",
          "match": "^\\s*(\\*)(\\[)([A-Z][A-Z0-9]*)(\\])(:)\\s+(.*)$",
          "captures": {
            "1": {
              "name": "keyword.control.abbreviation.carve"
            },
            "2": {
              "name": "keyword.control.abbreviation.carve"
            },
            "3": {
              "name": "entity.name.abbreviation.carve"
            },
            "4": {
              "name": "keyword.control.abbreviation.carve"
            },
            "5": {
              "name": "keyword.control.separator.carve"
            },
            "6": {
              "name": "string.unquoted.abbreviation.carve"
            }
          }
        }
      ]
    },
    "links": {
      "patterns": [
        {
          "name": "meta.link.inline.carve",
          "comment": "The optional title may be empty (`[x](u \"\")`) and may contain escaped quotes (`\"ti\\\"tle\"`), so the title run allows backslash escapes and zero characters.",
          "match": "(\\[)([^\\]]+)(\\])(\\()([^\\s)]+)(?:\\s+\"((?:[^\"\\\\]|\\\\.)*)\")?(\\))",
          "captures": {
            "1": {
              "name": "keyword.control.link.begin.carve"
            },
            "2": {
              "name": "string.other.link.title.carve"
            },
            "3": {
              "name": "keyword.control.link.end.carve"
            },
            "4": {
              "name": "keyword.control.metadata.begin.carve"
            },
            "5": {
              "name": "markup.underline.link.carve"
            },
            "6": {
              "name": "string.quoted.double.link-title.carve"
            },
            "7": {
              "name": "keyword.control.metadata.end.carve"
            }
          }
        },
        {
          "name": "meta.link.reference.carve",
          "match": "(\\[)([^\\]]+)(\\])(\\[)([^\\]]*)(\\])",
          "captures": {
            "2": {
              "name": "string.other.link.title.carve"
            },
            "5": {
              "name": "entity.name.reference.link.carve"
            }
          }
        },
        {
          "name": "meta.span.inline.carve",
          "match": "(\\[)([^\\^\\]][^\\]]*)(\\])(?=\\{)",
          "captures": {
            "1": {
              "name": "keyword.control.span.begin.carve"
            },
            "2": {
              "name": "string.other.span.carve"
            },
            "3": {
              "name": "keyword.control.span.end.carve"
            }
          }
        }
      ]
    },
    "images": {
      "patterns": [
        {
          "name": "meta.image.inline.carve",
          "comment": "The optional title may be empty and may contain escaped quotes; see the inline-link rule.",
          "match": "(!\\[)([^\\]]*)(\\]\\()([^\\s)]+)(?:\\s+\"((?:[^\"\\\\]|\\\\.)*)\")?(\\))",
          "captures": {
            "1": {
              "name": "keyword.control.image.begin.carve"
            },
            "2": {
              "name": "string.other.image.alt.carve"
            },
            "4": {
              "name": "markup.underline.link.image.carve"
            },
            "5": {
              "name": "string.quoted.double.image-title.carve"
            }
          }
        }
      ]
    },
    "footnotes": {
      "patterns": [
        {
          "match": "(\\^\\[)([^\\]\\n]*)(\\])",
          "captures": {
            "1": {
              "name": "keyword.control.footnote.carve"
            },
            "2": {
              "name": "string.other.footnote.inline.carve"
            },
            "3": {
              "name": "keyword.control.footnote.carve"
            }
          }
        },
        {
          "name": "entity.name.reference.footnote.carve",
          "match": "(\\[)(\\^)([^\\]]+)(\\])",
          "captures": {
            "1": {
              "name": "keyword.control.footnote.carve"
            },
            "2": {
              "name": "keyword.control.footnote.carve"
            },
            "3": {
              "name": "variable.parameter.footnote.carve"
            },
            "4": {
              "name": "keyword.control.footnote.carve"
            }
          }
        }
      ]
    },
    "citations": {
      "comment": "Citation group: a bracket whose content contains at least one @key and has no (url)/[ref]/{attrs} tail. A leading + signals an integral/in-text citation. Items are ;-separated; each may carry a -/+ prefix and an optional , locator. The @key and the -/+ per-item markers are scoped distinctly, analogous to @mention but inside the citation bracket.",
      "patterns": [
        {
          "name": "entity.name.citation.carve",
          "comment": "Match the whole citation bracket [+?...@key...] that is NOT followed by (, [, or { (which would make it a link, ref-link, or span). A lookahead for @ inside the brackets discriminates from plain spans and footnote refs.",
          "begin": "(?<!!)(?<![\\\\])(\\[)(\\+)?(?=[^\\]\\n]*@[A-Za-z0-9_][^\\]\\n]*\\](?!\\(|\\[|\\{))",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.citation.begin.carve"
            },
            "2": {
              "name": "keyword.control.citation.integral.carve"
            }
          },
          "end": "(\\])(?!\\(|\\[|\\{)",
          "endCaptures": {
            "1": {
              "name": "keyword.control.citation.end.carve"
            }
          },
          "patterns": [
            {
              "comment": "Optional -/+ per-item modifier immediately before the @key",
              "name": "keyword.control.citation.modifier.carve",
              "match": "(?<=^|;|\\[|\\+)\\s*(-)"
            },
            {
              "comment": "@key: citation key with allowed charset [A-Za-z0-9_][A-Za-z0-9_:.#$%&+?<>~/-]*",
              "name": "variable.parameter.citation.key.carve",
              "match": "@[A-Za-z0-9_][A-Za-z0-9_:.#$%&+?<>~\\/-]*"
            },
            {
              "comment": "Semicolon item separator",
              "name": "keyword.control.separator.citation.carve",
              "match": ";"
            }
          ]
        }
      ]
    },
    "code-callouts": {
      "comment": "CodeCallout markers: <N> where N is one or more digits. Leading form at the start of a callout annotation line (^<N> prose); trailing form inside fenced-code body lines (code  <N>). Both share the same scope.",
      "patterns": [
        {
          "comment": "Leading callout annotation line: <N> at the very start (with optional leading whitespace), followed by a space and annotation prose.",
          "name": "markup.callout.annotation.carve",
          "match": "^(\\s*)(<)([0-9]+)(>)(?=\\s)",
          "captures": {
            "2": {
              "name": "keyword.control.callout.carve"
            },
            "3": {
              "name": "constant.numeric.callout.carve"
            },
            "4": {
              "name": "keyword.control.callout.carve"
            }
          }
        },
        {
          "comment": "Trailing callout marker inside a code line: <N> at the end of the line (optionally preceded by whitespace).",
          "name": "markup.callout.marker.carve",
          "match": "(<)([0-9]+)(>)\\s*$",
          "captures": {
            "1": {
              "name": "keyword.control.callout.carve"
            },
            "2": {
              "name": "constant.numeric.callout.carve"
            },
            "3": {
              "name": "keyword.control.callout.carve"
            }
          }
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "meta.attributes.carve",
          "comment": "The empty / whitespace-only block is a blessed EMPTY attribute block only when it directly abuts the `]` of a span (grammar.ebnf: `[text]{}` / `[text]{ }` -> bare `<span>`). Elsewhere it is literal: on its own line (corpus 123) and after an image or link destination (corpus 75-3). The `(?<=\\])` guard encodes exactly that adjacency.",
          "match": "(?<=\\])(\\{)(\\s*)(\\})"
        },
        {
          "name": "meta.attributes.carve",
          "comment": "Strict identifier (spec PART 9 S14, corpus 122): a class/id/key may not start with a digit, so `{2=v}` stays literal text. An unquoted value may still contain dots and colons (corpus 110); a quoted value may contain braces and backslash-escaped quotes (corpus 64-3/64-9/64-11); a bare `{}` is literal (corpus 123).",
          "match": "(\\{)(\\s*(?:[.#][A-Za-z_][\\w-]*|[A-Za-z_][\\w-]*(?:=(?:\"(?:[^\"\\\\\\n]|\\\\.)*\"|'(?:[^'\\\\\\n]|\\\\.)*'|[^\\s\"'{}]+))?)(?:\\s+(?:[.#][A-Za-z_][\\w-]*|[A-Za-z_][\\w-]*(?:=(?:\"(?:[^\"\\\\\\n]|\\\\.)*\"|'(?:[^'\\\\\\n]|\\\\.)*'|[^\\s\"'{}]+))?))*\\s*)(\\})",
          "captures": {
            "0": {
              "patterns": [
                {
                  "name": "entity.other.attribute-name.id.carve",
                  "match": "#[A-Za-z_][A-Za-z0-9_-]*"
                },
                {
                  "name": "entity.other.attribute-name.class.carve",
                  "match": "\\.[A-Za-z_][A-Za-z0-9_-]*"
                },
                {
                  "name": "entity.other.attribute-name.carve",
                  "match": "[A-Za-z_:][A-Za-z0-9_:-]*(?==)"
                },
                {
                  "name": "string.quoted.double.attribute.carve",
                  "match": "\"(?:[^\"\\\\]|\\\\.)*\""
                },
                {
                  "name": "string.quoted.single.attribute.carve",
                  "match": "'(?:[^'\\\\]|\\\\.)*'"
                }
              ]
            }
          }
        }
      ]
    },
    "raw-inline": {
      "patterns": [
        {
          "name": "markup.raw.inline.passthrough.carve",
          "match": "(`+)([^`]|[^`][\\s\\S]*?[^`])(\\1)(\\{=)([A-Za-z_][\\w-]*)(\\})",
          "captures": {
            "1": {
              "name": "keyword.control.raw.carve"
            },
            "2": {
              "name": "markup.raw.inline.content.carve"
            },
            "3": {
              "name": "keyword.control.raw.carve"
            },
            "4": {
              "name": "keyword.control.raw.format.begin.carve"
            },
            "5": {
              "name": "entity.name.type.format.carve"
            },
            "6": {
              "name": "keyword.control.raw.format.end.carve"
            }
          }
        }
      ]
    },
    "inline-code": {
      "patterns": [
        {
          "name": "markup.raw.inline.carve",
          "match": "(`+)([^`]|[^`][\\s\\S]*?[^`])(\\1)",
          "captures": {
            "1": {
              "name": "keyword.control.raw.carve"
            },
            "2": {
              "name": "markup.raw.inline.content.carve"
            },
            "3": {
              "name": "keyword.control.raw.carve"
            }
          }
        }
      ]
    },
    "inline-literal": {
      "patterns": [
        {
          "name": "markup.raw.inline.literal.carve",
          "begin": "(!)(`+)",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.literal.carve"
            },
            "2": {
              "name": "keyword.control.raw.carve"
            }
          },
          "end": "(\\2)",
          "endCaptures": {
            "1": {
              "name": "keyword.control.raw.carve"
            }
          },
          "contentName": "markup.raw.inline.content.carve"
        }
      ]
    },
    "math": {
      "patterns": [
        {
          "name": "markup.other.math.display.carve",
          "begin": "(\\$\\$)(`+)",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.math.carve"
            },
            "2": {
              "name": "keyword.control.raw.carve"
            }
          },
          "end": "(\\2)",
          "endCaptures": {
            "1": {
              "name": "keyword.control.raw.carve"
            }
          },
          "contentName": "markup.other.math.content.carve"
        },
        {
          "name": "markup.other.math.inline.carve",
          "begin": "(\\$)(`+)",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.math.carve"
            },
            "2": {
              "name": "keyword.control.raw.carve"
            }
          },
          "end": "(\\2)",
          "endCaptures": {
            "1": {
              "name": "keyword.control.raw.carve"
            }
          },
          "contentName": "markup.other.math.content.carve"
        }
      ]
    },
    "autolink": {
      "patterns": [
        {
          "name": "meta.link.autolink.carve",
          "match": "(<)([a-zA-Z][a-zA-Z0-9+.\\-]*:[^>\\s]+)(>)",
          "captures": {
            "1": {
              "name": "keyword.control.link.carve"
            },
            "2": {
              "name": "markup.underline.link.carve"
            },
            "3": {
              "name": "keyword.control.link.carve"
            }
          }
        },
        {
          "name": "meta.link.autolink.email.carve",
          "match": "(<)([A-Za-z0-9._%+\\-]+@[A-Za-z0-9.\\-]+\\.[A-Za-z]{2,})(>)",
          "captures": {
            "1": {
              "name": "keyword.control.link.carve"
            },
            "2": {
              "name": "markup.underline.link.carve"
            },
            "3": {
              "name": "keyword.control.link.carve"
            }
          }
        }
      ]
    },
    "extension-inline": {
      "patterns": [
        {
          "name": "meta.extension.inline.carve",
          "match": "(:)([a-zA-Z][\\w-]*)(\\[)([^\\]]*)(\\])(\\{[^}]*\\})?",
          "captures": {
            "1": {
              "name": "keyword.control.extension.carve"
            },
            "2": {
              "name": "entity.name.function.extension.carve"
            },
            "3": {
              "name": "keyword.control.extension.carve"
            },
            "4": {
              "name": "string.unquoted.extension.carve"
            },
            "5": {
              "name": "keyword.control.extension.carve"
            },
            "6": {
              "name": "meta.attributes.carve"
            }
          }
        }
      ]
    },
    "critic-markup": {
      "patterns": [
        {
          "name": "markup.inserted.critic.carve",
          "match": "(\\{\\+)([^}]*)(\\+\\})",
          "captures": {
            "1": {
              "name": "keyword.control.critic.carve"
            },
            "2": {
              "name": "markup.inserted.carve"
            },
            "3": {
              "name": "keyword.control.critic.carve"
            }
          }
        },
        {
          "name": "markup.deleted.critic.carve",
          "match": "(\\{-)([^}]*)(- \\}|\\-\\})",
          "captures": {
            "1": {
              "name": "keyword.control.critic.carve"
            },
            "2": {
              "name": "markup.deleted.carve"
            },
            "3": {
              "name": "keyword.control.critic.carve"
            }
          }
        },
        {
          "name": "markup.changed.critic.carve",
          "match": "(\\{~)([^~]*)(~>)([^~]*)(~\\})",
          "captures": {
            "1": {
              "name": "keyword.control.critic.carve"
            },
            "2": {
              "name": "markup.deleted.carve"
            },
            "3": {
              "name": "keyword.control.critic.carve"
            },
            "4": {
              "name": "markup.inserted.carve"
            },
            "5": {
              "name": "keyword.control.critic.carve"
            }
          }
        },
        {
          "name": "comment.block.critic.carve",
          "match": "(\\{#)([^}]*)(#\\})",
          "captures": {
            "1": {
              "name": "keyword.control.critic.carve"
            },
            "2": {
              "name": "comment.block.content.carve"
            },
            "3": {
              "name": "keyword.control.critic.carve"
            }
          }
        }
      ]
    },
    "emphasis": {
      "comment": "The bare emphasis delimiter set is `/ * _ ~ =`. Superscript and subscript are braced-only (`{^sup^}` / `{,sub,}`): a bare `^text^` or `,text,` is literal text and gets no emphasis scope, so no rule matches them here. The caret keeps its other, unrelated roles (line-start `^ ` captions, table header rowspan `^` cells, `^[...]` inline footnotes), which are matched by their own rules outside this emphasis group.",
      "patterns": [
        {
          "match": "(\\{=)(?=\\S)([^\\n]*?)(=\\})",
          "captures": {
            "1": {
              "name": "keyword.control.highlight.carve"
            },
            "2": {
              "name": "markup.changed.carve"
            },
            "3": {
              "name": "keyword.control.highlight.carve"
            }
          }
        },
        {
          "match": "(\\{,)(?=\\S)([^,\\n]+?)(,\\})",
          "captures": {
            "1": {
              "name": "keyword.control.subscript.carve"
            },
            "2": {
              "name": "markup.subscript.carve"
            },
            "3": {
              "name": "keyword.control.subscript.carve"
            }
          }
        },
        {
          "match": "(\\{\\^)(?=\\S)([^\\n]*?)(\\^\\})",
          "captures": {
            "1": {
              "name": "keyword.control.superscript.carve"
            },
            "2": {
              "name": "markup.superscript.carve"
            },
            "3": {
              "name": "keyword.control.superscript.carve"
            }
          }
        },
        {
          "comment": "Forced intraword bold (PART 9 S22). The content runs to the closing `*}`, so it may contain the delimiter.",
          "name": "markup.bold.carve",
          "match": "(\\{\\*)(?=\\S)([^\\n]*?)(\\*\\})",
          "captures": {
            "1": {
              "name": "keyword.control.bold.carve"
            },
            "2": {
              "name": "markup.bold.carve"
            },
            "3": {
              "name": "keyword.control.bold.carve"
            }
          }
        },
        {
          "comment": "Forced intraword italic (PART 9 S22). The content runs to the closing `/}`, so it may contain the delimiter (`{/a/b/}` -> <em>a/b</em>, corpus 01-emphasis-13).",
          "name": "markup.italic.carve",
          "match": "(\\{/)(?=\\S)([^\\n]*?)(/\\})",
          "captures": {
            "1": {
              "name": "keyword.control.italic.carve"
            },
            "2": {
              "name": "markup.italic.carve"
            },
            "3": {
              "name": "keyword.control.italic.carve"
            }
          }
        },
        {
          "comment": "Forced intraword underline (PART 9 S22). `{_path_}` (corpus 01-emphasis-12) is shape-identical to a boolean attribute block, so this rule only wins because the whole emphasis group is listed before `#attributes`.",
          "name": "markup.underline.text.carve",
          "match": "(\\{_)(?=\\S)([^\\n]*?)(_\\})",
          "captures": {
            "1": {
              "name": "keyword.control.underline.carve"
            },
            "2": {
              "name": "markup.underline.text.carve"
            },
            "3": {
              "name": "keyword.control.underline.carve"
            }
          }
        },
        {
          "comment": "Forced intraword strikethrough (PART 9 S22). `#critic-markup` is listed first, so an editorial substitution `{~old~>new~}` still wins; only an arrow-less `{~x~}` lands here.",
          "name": "markup.deleted.carve",
          "match": "(\\{~)(?=\\S)([^\\n]*?)(~\\})",
          "captures": {
            "1": {
              "name": "keyword.control.strike.carve"
            },
            "2": {
              "name": "markup.deleted.carve"
            },
            "3": {
              "name": "keyword.control.strike.carve"
            }
          }
        },
        {
          "name": "markup.bold.italic.carve",
          "match": "(/\\*)(?=\\S)([^*]+)(\\*/)",
          "captures": {
            "1": {
              "name": "keyword.control.bold-italic.carve"
            },
            "2": {
              "name": "markup.bold.italic.carve"
            },
            "3": {
              "name": "keyword.control.bold-italic.carve"
            }
          }
        },
        {
          "name": "markup.bold.carve",
          "match": "(?<![\\w*])(\\*)(?=\\S)([^*\\n]+?)(?<=\\S)(\\*)(?![\\w*])",
          "captures": {
            "1": {
              "name": "keyword.control.bold.carve"
            },
            "2": {
              "name": "markup.bold.carve"
            },
            "3": {
              "name": "keyword.control.bold.carve"
            }
          }
        },
        {
          "name": "markup.italic.carve",
          "match": "(?<![\\w/])(/)(?=\\S)([^/\\n]+?)(?<=\\S)(/)(?![\\w/])",
          "captures": {
            "1": {
              "name": "keyword.control.italic.carve"
            },
            "2": {
              "name": "markup.italic.carve"
            },
            "3": {
              "name": "keyword.control.italic.carve"
            }
          }
        },
        {
          "name": "markup.underline.text.carve",
          "match": "(?<![\\w_])(_)(?=\\S)([^_\\n]+?)(?<=\\S)(_)(?![\\w_])",
          "captures": {
            "1": {
              "name": "keyword.control.underline.carve"
            },
            "2": {
              "name": "markup.underline.text.carve"
            },
            "3": {
              "name": "keyword.control.underline.carve"
            }
          }
        },
        {
          "name": "markup.deleted.carve",
          "match": "(?<![\\w~])(~)(?=\\S)([^~\\n]+?)(?<=\\S)(~)(?![\\w~])",
          "captures": {
            "1": {
              "name": "keyword.control.strike.carve"
            },
            "2": {
              "name": "markup.deleted.carve"
            },
            "3": {
              "name": "keyword.control.strike.carve"
            }
          }
        },
        {
          "name": "markup.changed.carve",
          "match": "(?<![\\w=])(=)(?=\\S)([^=\\n]+?)(?<=\\S)(=)(?![\\w=])",
          "captures": {
            "1": {
              "name": "keyword.control.highlight.carve"
            },
            "2": {
              "name": "markup.changed.carve"
            },
            "3": {
              "name": "keyword.control.highlight.carve"
            }
          }
        }
      ]
    },
    "mentions-tags": {
      "patterns": [
        {
          "name": "entity.name.mention.carve",
          "match": "(?<![\\w.])(@)([A-Za-z0-9_][A-Za-z0-9_-]*)",
          "captures": {
            "1": {
              "name": "keyword.control.mention.carve"
            },
            "2": {
              "name": "variable.parameter.mention.carve"
            }
          }
        },
        {
          "name": "entity.name.tag.hashtag.carve",
          "match": "(?<!\\w)(#)([A-Za-z0-9_][A-Za-z0-9_-]*)",
          "captures": {
            "1": {
              "name": "punctuation.definition.tag.carve"
            },
            "2": {
              "name": "variable.parameter.tag.carve"
            }
          }
        },
        {
          "name": "constant.character.entity.carve",
          "match": "(?<!\\w):[A-Za-z0-9+-][\\w+-]*:"
        }
      ]
    },
    "smart-typography": {
      "patterns": [
        {
          "name": "constant.character.escape.carve",
          "match": "\\\\[\\\\`*_{}\\[\\]()#+\\-.!~^/<>@%|=,]"
        },
        {
          "name": "constant.character.entity.typography.carve",
          "match": "\\.\\.\\.|---|--|<->|<-|->|=>|!=|<=|>=|\\+-|\\(c\\)|\\(r\\)|\\(tm\\)"
        },
        {
          "name": "keyword.control.smartquote.carve",
          "match": "\""
        }
      ]
    },
    "cross-reference": {
      "match": "(</#)([^>\\s]+)(>)",
      "captures": {
        "1": {
          "name": "keyword.control.link.begin.carve"
        },
        "2": {
          "name": "markup.underline.link.cross-reference.carve"
        },
        "3": {
          "name": "keyword.control.link.end.carve"
        }
      }
    },
    "hard-break": {
      "match": "(\\\\)$",
      "captures": {
        "1": {
          "name": "constant.character.escape.hard-break.carve"
        }
      }
    }
  }
}
