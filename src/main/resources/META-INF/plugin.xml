<idea-plugin>
    <id>org.markupcarve.carve</id>
    <name>Carve</name>
    <vendor email="dereuromark@gmail.com" url="https://github.com/markup-carve">markup-carve</vendor>

    <description><![CDATA[
    <p>Carve markup language support for JetBrains IDEs.</p>

    <h3>Features</h3>
    <ul>
        <li>Syntax highlighting via TextMate grammar</li>
        <li>Language Server features via the bundled carve-lsp server (optional -
            install the LSP4IJ plugin to enable; requires Node.js): diagnostics,
            completion, code folding, structure/outline, hover, quick
            fixes/intentions, rename, formatting, and semantic highlighting</li>
        <li>Live preview panel (split editor view)</li>
        <li>IDE theme sync - preview follows dark/light mode</li>
        <li>Export to HTML</li>
        <li>Live templates for quick element insertion (type <code>c</code> + Tab to see all)</li>
        <li>File type recognition for <code>.crv</code></li>
    </ul>

    <h3>About Carve</h3>
    <p>Carve is a post-Markdown lightweight markup language that builds on Djot with
    visual mnemonics (<code>/italic/</code>, <code>*bold*</code>, <code>_underline_</code>,
    <code>~strike~</code>, <code>=highlight=</code>) and a Markdown-like reading flow.</p>

    <p>More info: <a href="https://github.com/markup-carve/carve">github.com/markup-carve/carve</a></p>
    ]]></description>


    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.textmate</depends>
    <!--
      LSP4IJ is optional: the core plugin (highlighting, preview, export,
      templates) loads without it. When installed, carve-lsp.xml wires the
      language-server features. This avoids forcing users to install LSP4IJ just
      to get syntax highlighting and preview.
    -->
    <depends optional="true" config-file="carve-lsp.xml">com.redhat.devtools.lsp4ij</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="Carve" displayType="BALLOON"/>
        <fileType
                name="Carve"
                implementationClass="org.markupcarve.carve.CarveFileType"
                fieldName="INSTANCE"
                language="Carve"
                extensions="crv"/>

        <!-- Editor syntax highlighting via the bundled TextMate engine. -->
        <textmate.bundleProvider implementation="org.markupcarve.carve.CarveTextMateBundleProvider"/>
        <!--
          A custom file type otherwise shadows TextMate, so the TextMate highlighter
          is bound explicitly to the Carve file type / language (the BAML / fss pattern).
        -->
        <editorHighlighterProvider
                filetype="Carve"
                implementationClass="org.jetbrains.plugins.textmate.language.syntax.highlighting.TextMateEditorHighlighterProvider"/>
        <lang.syntaxHighlighterFactory
                language="Carve"
                implementationClass="org.jetbrains.plugins.textmate.language.syntax.highlighting.TextMateSyntaxHighlighterFactory"/>

        <!--
          A minimal PSI (single-token) so an Annotator runs on .crv files; without any
          ParserDefinition the file is plain text and no Carve annotator fires. TextMate still
          owns base editor highlighting; the annotator layers distinct, user-customizable
          colours onto the structural markers that TextMate collapses to one keyword colour.
        -->
        <lang.parserDefinition
                language="Carve"
                implementationClass="org.markupcarve.carve.lang.CarveParserDefinition"/>
        <annotator
                language="Carve"
                implementationClass="org.markupcarve.carve.highlight.CarveAnnotator"/>
        <colorSettingsPage
                implementation="org.markupcarve.carve.highlight.CarveColorSettingsPage"/>

        <fileEditorProvider
                implementation="org.markupcarve.carve.preview.CarvePreviewEditorProvider"/>

        <toolWindow
                id="Carve Preview"
                anchor="right"
                factoryClass="org.markupcarve.carve.preview.CarvePreviewToolWindowFactory"
                icon="/icons/carve.svg"/>

        <defaultLiveTemplates file="/liveTemplates/Carve.xml"/>

        <projectConfigurable
                instance="org.markupcarve.carve.settings.CarveSettingsConfigurable"
                id="org.markupcarve.carve.settings"
                displayName="Carve"
                parentId="tools"/>

        <projectService
                serviceImplementation="org.markupcarve.carve.settings.CarveSettings"/>
    </extensions>

    <!--
      The LSP4IJ extension points (Carve language server + language mapping) live
      in the optional carve-lsp.xml, loaded only when LSP4IJ is installed. See the
      optional <depends config-file="carve-lsp.xml"> above.
    -->

    <actions>
        <action id="Carve.Preview"
                class="org.markupcarve.carve.actions.TogglePreviewAction"
                text="Toggle Carve Preview"
                description="Show/hide Carve preview tool window"
                icon="/icons/carve.svg">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift D"/>
        </action>

        <action id="Carve.ExportHtml"
                class="org.markupcarve.carve.actions.ExportHtmlAction"
                text="Export to HTML"
                description="Export Carve file to HTML">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
